ings'); if (raw) this.setState({ bookings: JSON.parse(raw) }); } catch(e){}\n    try { const l = localStorage.getItem('mad_lang'); if (l === 'pl' || l === 'en') this.setState({ lang: l }); } catch(e){}\n  }\n  setLang(l){ this.setState({ lang: l }); try { localStorage.setItem('mad_lang', l); } catch(e){} }\n  save(b){ try { localStorage.setItem('mad_bookings', JSON.stringify(b)); } catch(e){} }\n  slotsFor(ds){\n    const d = new Date(ds + 'T00:00:00');\n    const day = d.getDay();\n    const weekend = (day === 0 || day === 6);\n    const start = weekend ? 9 : 17;\n    const end = weekend ? 18 : 21;\n    const out = [];\n    for (let h = start; h < end; h++) out.push(String(h).padStart(2,'0') + ':00');\n    return out;\n  }\n  selectDate(ds){ this.setState({ selectedDate: ds, selectedSlot: null, confirmed: null }); }\n  selectSlot(t){ this.setState({ selectedSlot: t }); }\n  setField(k, v){ this.setState(s => ({ form: { ...s.form, [k]: v } })); }\n  prevMonth(){\n    const { viewYear, viewMonth } = this.state;\n    if (viewYear < this.INIT.y || (viewYear === this.INIT.y && viewMonth <= this.INIT.m)) return;\n    let m = viewMonth - 1, y = viewYear;\n    if (m < 0){ m = 11; y--; }\n    this.setState({ viewYear: y, viewMonth: m });\n  }\n  nextMonth(){\n    let m = this.state.viewMonth + 1, y = this.state.viewYear;\n    if (m > 11){ m = 0; y++; }\n    if (y > 2027) return;\n    this.setState({ viewYear: y, viewMonth: m });\n  }\n  confirm(){\n    const { selectedDate, selectedSlot, form, bookings } = this.state;\n    if (!selectedDate || !selectedSlot || !form.name.trim() || !form.phone.trim() || !form.email.trim()) return;\n    const b = { ...bookings };\n    const arr = (b[selectedDate] || []).slice();\n    if (!arr.includes(selectedSlot)) arr.push(selectedSlot);\n    b[selectedDate] = arr;\n    this.save(b);\n    // Persist a full booking record for the staff dashboard\n    try {\n      const raw = localStorage.getItem('mad_records');\n      const records = raw ? JSON.parse(raw) : [];\n      records.push({\n        id: 'bk_' + Date.now() + '_' + Math.random().toString(36).slice(2,7),\n        createdAt: new Date().toISOString(),\n        date: selectedDate, slot: selectedSlot,\n        name: form.name, phone: form.phone, email: form.email, car: form.car,\n        address: form.address, comments: form.comments,\n        pkg: form.pkg, photo: !!form.photo, largeCar: !!form.largeCar,\n        status: 'new'\n      });\n      localStorage.setItem('mad_records', JSON.stringify(records));\n    } catch(e){}\n    this.setState({\n      bookings: b,\n      confirmed: { date: selectedDate, slot: selectedSlot, name: form.name, pkg: form.pkg, photo: form.photo },\n      selectedSlot: null\n    });\n  }\n  resetConfirm(){ this.setState({ confirmed: null, selectedDate: null }); }\n  fmtDate(ds, dict){\n    if (!ds) return '';\n    const d = new Date(ds + 'T00:00:00');\n    return `${dict.days[d.getDay()]}, ${d.getDate()} ${dict.months[d.getMonth()]} ${d.getFullYear()}`;\n  }\n  renderVals(){\n    const t = this.I18N[this.state.lang] || this.I18N.pl;\n    const C = { navy:'#282D31', blue:'#1F9E9A', cyan:'#1F9E9A', white:'#fff' };\n    const y = this.state.viewYear, m = this.state.viewMonth;\n    const startOffset = (new Date(y, m, 1).getDay() + 6) % 7;\n    const dim = new Date(y, m + 1, 0).getDate();\n    const cells = [];\n    for (let i = 0; i < startOffset; i++) cells.push({ key:'b'+i, label:'', freeLabel:'', style:'height:56px;', onClick:null });\n    for (let d = 1; d <= dim; d++){\n      const ds = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;\n      const selectable = ds >= this.MIN;\n      const slots = this.slotsFor(ds);\n      const booked = this.state.bookings[ds] || [];\n      const free = slots.length - booked.length;\n      const isSel = this.state.selectedDate === ds;\n      const bg = isSel ? C.blue : (selectable ? C.white : 'transparent');\n      const col = isSel ? C.white : (selectable ? C.navy : '#C0C7CB');\n      const border = isSel ? C.blue : (selectable ? '#DBDDD7' : '#ECEBE6');\n      const style = `display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;height:56px;border-radius:9px;border:1px solid ${border};background:${bg};color:${col};font-weight:600;font-size:15px;cursor:${selectable?'pointer':'default'};transition:background .15s,border-color .15s;`;\n      cells.push({\n        key: ds, label: String(d),\n        freeLabel: selectable ? (free > 0 ? free + ' ' + t.free : t.full) : '',\n        style,\n        onClick: selectable ? (() => this.selectDate(ds)) : null\n      });\n    }\n    while (cells.length % 7 !== 0) cells.push({ key:'e'+cells.length, label:'', freeLabel:'', style:'height:56px;', onClick:null });\n\n    let slots = [];\n    if (this.state.selectedDate){\n      const all = this.slotsFor(this.state.selectedDate);\n      const booked = this.state.bookings[this.state.selectedDate] || [];\n      slots = all.map(time => {\n        const isBooked = booked.includes(time);\n        const isSel = this.state.selectedSlot === time;\n        const bg = isBooked ? '#ECEBE6' : (isSel ? C.blue : C.white);\n        const col = isBooked ? '#A6ADB2' : (isSel ? C.white : C.navy);\n        const border = isSel ? C.blue : '#DBDDD7';\n        const style = `padding:12px 6px;border-radius:9px;border:1px solid ${border};background:${bg};color:${col};font-weight:600;font-size:15px;text-align:center;cursor:${isBooked?'not-allowed':'pointer'};text-decoration:${isBooked?'line-through':'none'};transition:background .15s,border-color .15s;`;\n        return { key: time, time, style, onClick: isBooked ? null : (() => this.selectSlot(time)) };\n      });\n    }\n\n    const canConfirm = !!(this.state.selectedDate && this.state.selectedSlot && this.state.form.name.trim() && this.state.form.phone.trim() && this.state.form.email.trim());\n    const confirmBtnStyle = `margin-top:6px;padding:15px;border-radius:10px;border:none;background:${C.blue};color:#fff;font-weight:700;font-size:16px;cursor:${canConfirm?'pointer':'not-allowed'};opacity:${canConfirm?1:.45};box-shadow:${canConfirm?'0 8px 20px rgba(31,158,154,.3)':'none'};transition:opacity .15s;`;\n\n    const conf = this.state.confirmed;\n    const confLine = conf ? `${this.fmtDate(conf.date, t)} · ${t.confAt} ${conf.slot}` : '';\n\n    const pkgKeys = ['Essential — 299 PLN','Complete — 499 PLN','Showroom — 999 PLN'];\n    const pkgLabels = pkgKeys.slice();\n    const pkgOptions = pkgKeys.map((v,i) => ({ key:v, value:v, label:pkgLabels[i] }));\n    let confPkgLabel = '';\n    if (conf){ const ix = pkgKeys.indexOf(conf.pkg); confPkgLabel = ix >= 0 ? pkgLabels[ix] : conf.pkg; }\n\n    const ls = this.props.logoStyle || 'Ikona + nazwa';\n    const feat = this.props.featuredPackage || 'Complete';\n    const plActive = this.state.lang === 'pl';\n\n    return {\n      t,\n      monthLabel: `${t.months[m]} ${y}`,\n      bookMailto: 'mailto:booking@mobileautodetail.pl?subject=' + encodeURIComponent(this.state.lang === 'pl' ? 'Rezerwacja detailingu' : 'Detailing booking') + '&body=' + encodeURIComponent(this.state.lang === 'pl'\n        ? 'Dzień dobry,\\n\\nChciałbym umówić detailing:\\n\\n- Auto (marka / model): \\n- Pakiet: \\n- Adres: \\n- Preferowany termin: \\n- Uwagi: \\n\\nPozdrawiam,'\n        : 'Hello,\\n\\nI\\u2019d like to book a detailing:\\n\\n- Car (make / model): \\n- Package: \\n- Address: \\n- Preferred date: \\n- Notes: \\n\\nThank you,'),\n      cells, slots,\n      pkgOptions, confPkgLabel,\n      galleryPairs: (t.galleryItems || []).map((title, i) => ({ key:'g'+i, title })),\n      selectedDateLabel: this.fmtDate(this.state.selectedDate, t),\n      showPrompt: !this.state.selectedDate && !this.state.confirmed,\n      showSlots: !!this.state.selectedDate && !this.state.confirmed,\n      showConfirmed: !!this.state.confirmed,\n      confLine,\n      photoLabel: conf ? (conf.photo ? t.yes : t.no) : '',\n      confirmed: conf || {},\n      form: this.state.form,\n      confirmBtnStyle,\n      confirmDisabled: !canConfirm,\n      prevMonth: () => this.prevMonth(),\n      nextMonth: () => this.nextMonth(),\n      setPL: () => this.setLang('pl'),\n      setEN: () => this.setLang('en'),\n      plBtnStyle: `padding:7px 12px;border:none;background:${plActive?'#282D31':'#fff'};color:${plActive?'#fff':'#6E7880'};font-weight:700;font-size:13px;line-height:1;cursor:pointer;`,\n      enBtnStyle: `padding:7px 12px;border:none;border-left:1px solid #DBDDD7;background:${!plActive?'#282D31':'#fff'};color:${!plActive?'#fff':'#6E7880'};font-weight:700;font-size:13px;line-height:1;cursor:pointer;`,\n      onName: (e) => this.setField('name', e.target.value),\n      onPhone: (e) => this.setField('phone', e.target.value),\n      onEmail: (e) => this.setField('email', e.target.value),\n      onCar: (e) => this.setField('car', e.target.value),\n      onAddress: (e) => this.setField('address', e.target.value),\n      onComments: (e) => this.setField('comments', e.target.value),\n      onPkg: (e) => this.setField('pkg', e.target.value),\n      onPhoto: (e) => this.setField('photo', e.target.checked),\n      onLargeCar: (e) => this.setField('largeCar', e.target.checked),\n      confirm: () => this.confirm(),\n      resetConfirm: () => this.resetConfirm(),\n      isLogoA: ls === 'Tylko nazwa',\n      isLogoB: ls === 'Ikona + nazwa',\n      isLogoC: ls === 'Kafelek + monogram',\n      featBasic: false,\n      featMedium: false,\n      featPremium: false\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
